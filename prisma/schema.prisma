import { prisma } from "@/lib/prisma";
import Link from "next/link";
import {
  MapPin,
  Car,
  DollarSign,
  ClipboardList,
  TrendingUp,
  Clock,
  CheckCircle2,
  XCircle,
  ArrowUpRight,
} from "lucide-react";

export default async function AdminDashboard() {
  const startOfMonth = new Date();
  startOfMonth.setDate(1);
  startOfMonth.setHours(0, 0, 0, 0);

  const startOfLastMonth = new Date(startOfMonth);
  startOfLastMonth.setMonth(startOfLastMonth.getMonth() - 1);

  const [
    locationCount,
    vehicleCount,
    rateCount,
    bookingCount,
    pendingCount,
    confirmedCount,
    completedCount,
    cancelledCount,
    thisMonthBookings,
    lastMonthBookings,
    revenueAgg,
    recentBookings,
  ] = await Promise.all([
    prisma.location.count(),
    prisma.vehicle.count(),
    prisma.rate.count(),
    prisma.booking.count(),
    prisma.booking.count({ where: { status: "pending" } }),
    prisma.booking.count({ where: { status: "confirmed" } }),
    prisma.booking.count({ where: { status: "completed" } }),
    prisma.booking.count({ where: { status: "cancelled" } }),
    prisma.booking.count({ where: { createdAt: { gte: startOfMonth } } }),
    prisma.booking.count({
      where: { createdAt: { gte: startOfLastMonth, lt: startOfMonth } },
    }),
    prisma.booking.aggregate({
      _sum: { price: true },
      where: { status: { in: ["confirmed", "completed"] } },
    }),
    prisma.booking.findMany({
      take: 6,
      orderBy: { createdAt: "desc" },
      select: {
        id: true,
        name: true,
        fromText: true,
        toText: true,
        vehicleName: true,
        price: true,
        status: true,
        date: true,
        time: true,
        createdAt: true,
      },
    }),
  ]);

  const totalRevenue = revenueAgg._sum.price ?? 0;
  const momChange =
    lastMonthBookings === 0
      ? thisMonthBookings > 0
        ? 100
        : 0
      : Math.round(
          ((thisMonthBookings - lastMonthBookings) / lastMonthBookings) * 100
        );

  const cards = [
    { label: "Locations", value: locationCount, href: "/admin/locations", icon: MapPin, color: "bg-blue-500" },
    { label: "Vehicles", value: vehicleCount, href: "/admin/vehicles", icon: Car, color: "bg-purple-500" },
    { label: "Routes Priced", value: rateCount, href: "/admin/rates", icon: DollarSign, color: "bg-green-500" },
    { label: "Total Bookings", value: bookingCount, href: "/admin/bookings", icon: ClipboardList, color: "bg-yellow-500" },
  ];

  const statusBreakdown = [
    { label: "Pending", value: pendingCount, icon: Clock, color: "text-yellow-600 bg-yellow-50 border-yellow-200" },
    { label: "Confirmed", value: confirmedCount, icon: CheckCircle2, color: "text-blue-600 bg-blue-50 border-blue-200" },
    { label: "Completed", value: completedCount, icon: CheckCircle2, color: "text-green-600 bg-green-50 border-green-200" },
    { label: "Cancelled", value: cancelledCount, icon: XCircle, color: "text-red-600 bg-red-50 border-red-200" },
  ];

  const statusStyles: Record<string, string> = {
    pending: "bg-yellow-50 text-yellow-700 border-yellow-200",
    confirmed: "bg-blue-50 text-blue-700 border-blue-200",
    completed: "bg-green-50 text-green-700 border-green-200",
    cancelled: "bg-red-50 text-red-700 border-red-200",
  };

  return (
    <div>
      <div className="flex items-center justify-between mb-1">
        <h1 className="text-2xl font-bold text-gray-900">Dashboard</h1>
        <span className="text-xs text-gray-400">
          {new Date().toLocaleDateString(undefined, { month: "long", year: "numeric" })}
        </span>
      </div>
      <p className="text-gray-500 mb-8">Overview of your booking system master data.</p>

      {/* Top stat cards */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {cards.map((c) => (
          <Link
            key={c.label}
            href={c.href}
            className="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md transition-shadow"
          >
            <div className={`w-10 h-10 ${c.color} rounded-lg flex items-center justify-center text-white mb-3`}>
              <c.icon className="w-5 h-5" />
            </div>
            <p className="text-3xl font-bold text-gray-900">{c.value}</p>
            <p className="text-sm text-gray-500">{c.label}</p>
          </Link>
        ))}
      </div>

      {/* Revenue + MoM growth */}
      <div className="grid grid-cols-1 sm:grid-cols-2 gap-5 mt-5">
        <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <p className="text-sm text-gray-500 mb-1">Total Revenue (confirmed + completed)</p>
          <p className="text-3xl font-bold text-gray-900">
            €{totalRevenue.toLocaleString(undefined, { minimumFractionDigits: 2 })}
          </p>
        </div>
        <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
          <p className="text-sm text-gray-500 mb-1">Bookings This Month vs Last</p>
          <div className="flex items-center gap-3">
            <p className="text-3xl font-bold text-gray-900">{thisMonthBookings}</p>
            <span
              className={`flex items-center gap-1 text-sm font-medium ${
                momChange >= 0 ? "text-green-600" : "text-red-600"
              }`}
            >
              <TrendingUp className={`w-4 h-4 ${momChange < 0 ? "rotate-180" : ""}`} />
              {momChange >= 0 ? "+" : ""}
              {momChange}%
            </span>
          </div>
          <p className="text-xs text-gray-400 mt-1">{lastMonthBookings} last month</p>
        </div>
      </div>

      {/* Status breakdown */}
      <div className="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-5">
        {statusBreakdown.map((s) => (
          <div key={s.label} className={`rounded-xl border p-4 ${s.color}`}>
            <div className="flex items-center justify-between mb-2">
              <s.icon className="w-4 h-4" />
              <span className="text-2xl font-bold">{s.value}</span>
            </div>
            <p className="text-xs font-medium">{s.label}</p>
          </div>
        ))}
      </div>

      {pendingCount > 0 && (
        <div className="mt-6 bg-yellow-50 border border-yellow-300 text-yellow-800 rounded-xl p-4 text-sm">
          You have <strong>{pendingCount}</strong> pending booking(s) awaiting confirmation.{" "}
          <Link href="/admin/bookings" className="underline font-semibold">Review them</Link>.
        </div>
      )}

      {/* Recent bookings table */}
      <div className="mt-8 bg-white rounded-xl shadow-sm border border-gray-200">
        <div className="flex items-center justify-between p-6 pb-4">
          <h2 className="font-semibold text-gray-900">Recent Bookings</h2>
          <Link
            href="/admin/bookings"
            className="text-sm text-blue-600 hover:text-blue-700 font-medium flex items-center gap-1"
          >
            View all <ArrowUpRight className="w-3.5 h-3.5" />
          </Link>
        </div>
        {recentBookings.length === 0 ? (
          <p className="px-6 pb-6 text-sm text-gray-400">No bookings yet.</p>
        ) : (
          <div className="overflow-x-auto">
            <table className="w-full text-sm">
              <thead>
                <tr className="border-t border-gray-100 text-gray-500 text-xs uppercase tracking-wide">
                  <th className="text-left font-medium px-6 py-3">Customer</th>
                  <th className="text-left font-medium px-6 py-3">Route</th>
                  <th className="text-left font-medium px-6 py-3">Vehicle</th>
                  <th className="text-left font-medium px-6 py-3">Price</th>
                  <th className="text-left font-medium px-6 py-3">Status</th>
                  <th className="text-left font-medium px-6 py-3">Trip Date</th>
                </tr>
              </thead>
              <tbody>
                {recentBookings.map((b) => (
                  <tr key={b.id} className="border-t border-gray-100 hover:bg-gray-50">
                    <td className="px-6 py-3 font-medium text-gray-900">{b.name}</td>
                    <td className="px-6 py-3 text-gray-600">
                      {b.fromText} → {b.toText}
                    </td>
                    <td className="px-6 py-3 text-gray-600">{b.vehicleName}</td>
                    <td className="px-6 py-3 text-gray-900">
                      €{Number(b.price).toLocaleString(undefined, { minimumFractionDigits: 2 })}
                    </td>
                    <td className="px-6 py-3">
                      <span
                        className={`inline-block px-2.5 py-1 rounded-full text-xs font-medium border ${
                          statusStyles[b.status] ?? "bg-gray-50 text-gray-700 border-gray-200"
                        }`}
                      >
                        {b.status}
                      </span>
                    </td>
                    <td className="px-6 py-3 text-gray-500">
                      {new Date(b.date).toLocaleDateString()} · {b.time}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      {/* Setup checklist */}
      <div className="mt-8 bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 className="font-semibold text-gray-900 mb-2">Setup checklist</h2>
        <ol className="list-decimal list-inside text-sm text-gray-600 space-y-1">
          <li>Add your pickup/drop-off <strong>Locations</strong> (Airports, Landmarks, Hotels...)</li>
          <li>Add your <strong>Vehicles</strong> (fleet, capacity, base price, image)</li>
          <li>Go to <strong>Rates</strong> and set a specific price per vehicle for each From → To route</li>
          <li>Bookings placed on the public site will appear under <strong>Bookings</strong></li>
        </ol>
      </div>
    </div>
  );
}