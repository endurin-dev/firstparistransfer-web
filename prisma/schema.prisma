generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id          String   @id @default(cuid())
  tripType    String
  fromText    String
  toText      String
  date        DateTime
  time        String
  vehicleId   String?
  vehicleName String
  price       Float
  name        String
  country     String?
  phone       String
  email       String
  note        String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  Vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
}

model Location {
  id                                 String   @id @default(cuid())
  name                               String
  category                           String
  active                             Boolean  @default(true)
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt
  Rate_Rate_fromLocationIdToLocation Rate[]   @relation("Rate_fromLocationIdToLocation")
  Rate_Rate_toLocationIdToLocation   Rate[]   @relation("Rate_toLocationIdToLocation")

  @@unique([name, category])
}

model Rate {
  id                                     String   @id @default(cuid())
  fromLocationId                         String
  toLocationId                           String
  vehicleId                              String
  price                                  Float
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime @updatedAt
  Location_Rate_fromLocationIdToLocation Location @relation("Rate_fromLocationIdToLocation", fields: [fromLocationId], references: [id], onDelete: Cascade)
  Location_Rate_toLocationIdToLocation   Location @relation("Rate_toLocationIdToLocation", fields: [toLocationId], references: [id], onDelete: Cascade)
  Vehicle                                Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([fromLocationId, toLocationId, vehicleId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Vehicle {
  id         String    @id @default(cuid())
  name       String
  type       String
  passengers Int
  luggage    Int
  basePrice  Float
  image      String
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  Booking    Booking[]
  Rate       Rate[]
}
